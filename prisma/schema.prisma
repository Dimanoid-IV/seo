  executionJobs IntegrationExecutionJob[]

  @@unique([websiteId, provider])
  @@index([websiteId])
  @@index([organizationId])
  @@index([provider])
  @@index([status])
  @@index([lastSyncAt])
  @@map("integrations")
}

