/// WordPress connector — apiKeyHash is SHA-256 hash for verification; secret encrypted.
model WordPressConnection {
  id                   String                    @id @default(uuid()) @db.Uuid
  websiteId            String                    @db.Uuid
  organizationId       String                    @db.Uuid
  status               WordPressConnectionStatus @default(PENDING)
  siteUrl              String
  pluginVersion        String?
  apiKeyHash           String
  /// AES-encrypted shared secret for HMAC
  apiSecretEncrypted   String?
  permissionsJson      Json
  lastPingAt           DateTime?
  lastDraftCreatedAt   DateTime?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  disconnectedAt       DateTime?

  website      Website      @relation(fields: [websiteId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  executionJobs IntegrationExecutionJob[]

  @@unique([websiteId, siteUrl])
  @@index([websiteId])
  @@index([organizationId])
  @@index([status])
  @@index([siteUrl])
  @@map("wordpress_connections")
}

/// Queued/recorded integration adapter actions (foundation only — no live publish/webhook yet).
model IntegrationExecutionJob {
  id                     String                         @id @default(uuid()) @db.Uuid
  organizationId         String                         @db.Uuid
  websiteId              String                         @db.Uuid
  integrationId          String?                        @db.Uuid
  wordpressConnectionId  String?                        @db.Uuid
  requestedByUserId      String?                        @db.Uuid
  approvedByUserId       String?                        @db.Uuid
  sourceType             IntegrationExecutionSourceType
  sourceId               String
  action                 IntegrationExecutionAction
  provider               IntegrationExecutionProvider
  mode                   IntegrationExecutionMode       @default(REVIEW_ONLY)
  status                 IntegrationExecutionStatus     @default(QUEUED)
  idempotencyKey         String                         @unique
  capability             String
  /// Sanitized preview only — never secrets or full HTML bodies.
  requestPreviewJson     Json?
  /// Sanitized result only — never secrets or full HTML bodies.
  resultJson             Json?
  externalId             String?
  externalUrl            String?
  errorCode              String?
  errorMessage           String?
  retryCount             Int                            @default(0)
  maxRetries             Int                            @default(3)
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt
  startedAt              DateTime?
  finishedAt             DateTime?

  organization        Organization         @relation(fields: [organizationId], references: [id])
  website             Website              @relation(fields: [websiteId], references: [id])
  integration         Integration?         @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  wordpressConnection WordPressConnection? @relation(fields: [wordpressConnectionId], references: [id], onDelete: SetNull)
  requestedByUser     User?                @relation("IntegrationExecutionRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  approvedByUser      User?                @relation("IntegrationExecutionApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  events              IntegrationExecutionEvent[]

  @@index([organizationId, createdAt])
  @@index([websiteId, createdAt])
  @@index([status, createdAt])
  @@index([provider, action])
  @@index([sourceType, sourceId])
  @@map("integration_execution_jobs")
}

model IntegrationExecutionEvent {
  id           String                       @id @default(uuid()) @db.Uuid
  jobId        String                       @db.Uuid
  type         String
  status       IntegrationExecutionStatus?
  message      String?
  /// Sanitized metadata only — never secrets.
  metadataJson Json?
  createdAt    DateTime                     @default(now())

  job IntegrationExecutionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
  @@map("integration_execution_events")
}

