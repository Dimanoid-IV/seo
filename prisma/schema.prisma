// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id                    String    @id @default(uuid()) @db.Uuid
  email                 String    @unique
  passwordHash          String?
  name                  String?
  avatarUrl             String?
  role                  UserRole  @default(USER)
  locale                Locale    @default(RU)
  timezone              String?
  emailVerified         Boolean   @default(false)
  emailVerifiedAt       DateTime?
  googleAuthId          String?
  stripeCustomerId      String?
  onboardingCompletedAt DateTime?
  lastLoginAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?

  ownedOrganizations    Organization[] @relation("OrganizationOwner")
  billingOrganizations  Organization[] @relation("OrganizationBilling")
  subscriptions         Subscription[]
  payments              Payment[]
  triggeredAudits       Audit[]        @relation("AuditTriggeredByUser")
  activities            Activity[]
  aiJobs                AIJob[]
  aiUsages              AIUsage[]
  emailLogs             EmailLog[]
  adminNotesCreated     AdminNote[]    @relation("AdminNoteAuthor")
  adminNotesReceived    AdminNote[]    @relation("AdminNoteTarget")
  errorLogs             ErrorLog[]
  timelineEvents        TimelineEvent[]
  websiteUserStates     WebsiteUserState[]
  socialPostsCreated    SocialPost[] @relation("SocialPostAuthor")
  monthlyAutopilotPlans MonthlyAutopilotPlan[]
  emailApprovals        EmailApproval[]
  usageCounters         UsageCounter[]
  onboardingState       OnboardingState?
  assistedSetupRequests AssistedSetupRequest[]
  integrationExecutionsRequested IntegrationExecutionJob[] @relation("IntegrationExecutionRequestedBy")
  integrationExecutionsApproved  IntegrationExecutionJob[] @relation("IntegrationExecutionApprovedBy")
  websitesLivePublishPaused      Website[] @relation("WebsiteLivePublishPausedBy")

  @@index([stripeCustomerId])
  @@index([googleAuthId])
  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

model Organization {
  id             String             @id @default(uuid()) @db.Uuid
  name           String
  slug           String?
  country        String?
  city           String?
  ownerUserId    String             @db.Uuid
  billingUserId  String?            @db.Uuid
  status         OrganizationStatus @default(ACTIVE)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?

  owner          User               @relation("OrganizationOwner", fields: [ownerUserId], references: [id])
  billingUser    User?              @relation("OrganizationBilling", fields: [billingUserId], references: [id])
  websites       Website[]
  subscriptions  Subscription[]
  payments       Payment[]
  planLimits            PlanLimit[]
  activities            Activity[]
  tasks                 Task[]
  monthlyPlans            MonthlyPlan[]
  monthlyAutopilotPlans   MonthlyAutopilotPlan[]
  emailApprovals          EmailApproval[]
  usageCounters           UsageCounter[]
  articles              Article[]
  socialPosts           SocialPost[]
  reports               Report[]
  integrations          Integration[]
  wordpressConnections  WordPressConnection[]
  aiJobs                AIJob[]
  aiUsages              AIUsage[]
  emailLogs             EmailLog[]
  adminNotes            AdminNote[]
  errorLogs             ErrorLog[]
  integrationExecutionJobs IntegrationExecutionJob[]

  @@index([ownerUserId])
  @@index([billingUserId])
  @@index([status])
  @@index([deletedAt])
  @@map("organizations")
}

model Website {
  id                      String          @id @default(uuid()) @db.Uuid
  organizationId          String          @db.Uuid
  url                     String
  displayName             String?
  niche                   WebsiteNiche?
  cms                     WebsiteCms?
  primaryLanguage         WebsiteLanguage @default(RU)
  contentLanguages        Json            @default("[]")
  businessGoals           Json?
  status                  WebsiteStatus   @default(ACTIVE)
  lastAuditAt             DateTime?
  currentGrowthScore      Int?
  currentAIReadinessScore Int?
  /// Emergency pause for live WordPress/webhook publish only (Prompt 11.53).
  autopilotLivePublishPaused Boolean      @default(false)
  autopilotLivePublishPausedAt DateTime?
  autopilotLivePublishPausedByUserId String? @db.Uuid
  autopilotLivePublishPauseReason String?
  /// First-customer scoped rollout flag (Prompt 11.55). OR with env allowlist.
  livePublishRolloutEnabled Boolean @default(false)
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  deletedAt               DateTime?

  organization            Organization            @relation(fields: [organizationId], references: [id])
  livePublishPausedByUser User?                   @relation("WebsiteLivePublishPausedBy", fields: [autopilotLivePublishPausedByUserId], references: [id], onDelete: SetNull)
  audits                  Audit[]
  auditChecks             AuditCheck[]
  growthScoreSnapshots    GrowthScoreSnapshot[]
  aiReadinessSnapshots    AIReadinessSnapshot[]
  activities              Activity[]
  tasks                   Task[]
  monthlyPlans            MonthlyPlan[]
  monthlyAutopilotPlans   MonthlyAutopilotPlan[]
  emailApprovals          EmailApproval[]
  usageCounters           UsageCounter[]
  articles                Article[]
  socialPosts             SocialPost[]
  reports                 Report[]
  integrations            Integration[]
  wordpressConnections    WordPressConnection[]
  aiJobs                  AIJob[]
  aiUsages                AIUsage[]
  emailLogs               EmailLog[]
  adminNotes              AdminNote[]
  errorLogs               ErrorLog[]
  timelineEvents          TimelineEvent[]
  websiteUserStates       WebsiteUserState[]
  onboardingStates        OnboardingState[]
  assistedSetupRequests   AssistedSetupRequest[]
  integrationExecutionJobs IntegrationExecutionJob[]

  @@unique([organizationId, url])
  @@index([organizationId])
  @@index([status])
  @@index([lastAuditAt])
  @@index([currentGrowthScore])
  @@index([deletedAt])
  @@index([autopilotLivePublishPaused])
  @@index([livePublishRolloutEnabled])
  @@map("websites")
}

model Subscription {
  id                   String             @id @default(uuid()) @db.Uuid
  organizationId       String             @db.Uuid
  userId               String?            @db.Uuid
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(INCOMPLETE)
  stripeCustomerId     String?
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  trialEndsAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  deletedAt            DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  user           User?        @relation(fields: [userId], references: [id])
  payments       Payment[]
  planLimits     PlanLimit[]

  @@index([organizationId])
  @@index([userId])
  @@index([status])
  @@index([plan])
  @@index([currentPeriodEnd])
  @@index([deletedAt])
  @@map("subscriptions")
}

model Payment {
  id                    String        @id @default(uuid()) @db.Uuid
  subscriptionId        String?       @db.Uuid
  organizationId        String        @db.Uuid
  userId                String?       @db.Uuid
  stripePaymentIntentId String?       @unique
  stripeInvoiceId       String?       @unique
  stripeEventId         String?       @unique
  amountCents           Int
  currency              String        @default("EUR")
  status                PaymentStatus @default(PENDING)
  type                  PaymentType
  paidAt                DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
  @@index([paidAt])
  @@index([createdAt])
  @@map("payments")
}

model PlanLimit {
  id                 String   @id @default(uuid()) @db.Uuid
  subscriptionId     String   @db.Uuid
  organizationId     String   @db.Uuid
  periodStart        DateTime
  periodEnd          DateTime
  auditsLimit        Int      @default(0)
  auditsUsed         Int      @default(0)
  articlesLimit      Int      @default(0)
  articlesUsed       Int      @default(0)
  socialPostsLimit   Int      @default(0)
  socialPostsUsed    Int      @default(0)
  aiCreditsLimitCents Int?
  aiCreditsUsedCents Int      @default(0)
  websitesLimit      Int      @default(1)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  subscription Subscription @relation(fields: [subscriptionId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([subscriptionId])
  @@index([organizationId])
  @@index([periodStart, periodEnd])
  @@map("plan_limits")
}

model UsageCounter {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  websiteId String?  @db.Uuid
  organizationId String @db.Uuid
  month     String
  key       UsageKey
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  website      Website?     @relation(fields: [websiteId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, userId, month, key])
  @@index([userId])
  @@index([websiteId])
  @@index([organizationId])
  @@index([month])
  @@index([key])
  @@map("usage_counters")
}

model Audit {
  id                String           @id @default(uuid()) @db.Uuid
  websiteId         String           @db.Uuid
  type              AuditType
  status            AuditStatus      @default(QUEUED)
  triggeredBy       AuditTriggeredBy
  triggeredByUserId String?          @db.Uuid
  growthScore       Int?
  aiReadinessScore  Int?
  summaryJson       Json?
  rawResultJson     Json?
  visiblePreviewJson Json?
  startedAt         DateTime?
  completedAt       DateTime?
  failedAt          DateTime?
  errorCode         String?
  errorMessage      String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?

  website               Website                 @relation(fields: [websiteId], references: [id])
  triggeredByUser       User?                   @relation("AuditTriggeredByUser", fields: [triggeredByUserId], references: [id])
  checks                AuditCheck[]
  growthScoreSnapshots  GrowthScoreSnapshot[]
  aiReadinessSnapshots  AIReadinessSnapshot[]
  tasks                 Task[]

  @@index([websiteId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([completedAt])
  @@index([deletedAt])
  @@map("audits")
}

model AuditCheck {
  id                  String             @id @default(uuid()) @db.Uuid
  auditId             String             @db.Uuid
  websiteId           String             @db.Uuid
  category            AuditCheckCategory
  code                String
  title               String
  description         String?
  severity            AuditCheckSeverity
  status              AuditCheckStatus
  scoreImpact         Int?
  isVisibleInPreview  Boolean            @default(false)
  recommendationJson  Json?
  evidenceJson        Json?
  createdAt           DateTime           @default(now())

  audit   Audit   @relation(fields: [auditId], references: [id], onDelete: Cascade)
  website Website @relation(fields: [websiteId], references: [id])

  @@index([auditId])
  @@index([websiteId])
  @@index([category])
  @@index([severity])
  @@index([status])
  @@index([isVisibleInPreview])
  @@index([code])
  @@map("audit_checks")
}

model GrowthScoreSnapshot {
  id            String      @id @default(uuid()) @db.Uuid
  websiteId     String      @db.Uuid
  auditId       String?     @db.Uuid
  score         Int
  previousScore Int?
  delta         Int?
  breakdownJson Json
  reason        String?
  source        ScoreSource
  createdAt     DateTime    @default(now())

  website Website @relation(fields: [websiteId], references: [id])
  audit   Audit?  @relation(fields: [auditId], references: [id])

  @@index([websiteId])
  @@index([auditId])
  @@index([createdAt])
  @@index([score])
  @@map("growth_score_snapshots")
}

model AIReadinessSnapshot {
  id            String      @id @default(uuid()) @db.Uuid
  websiteId     String      @db.Uuid
  auditId       String?     @db.Uuid
  score         Int
  previousScore Int?
  delta         Int?
  breakdownJson Json
  reason        String?
  source        ScoreSource
  createdAt     DateTime    @default(now())

  website Website @relation(fields: [websiteId], references: [id])
  audit   Audit?  @relation(fields: [auditId], references: [id])

  @@index([websiteId])
  @@index([auditId])
  @@index([createdAt])
  @@index([score])
  @@map("ai_readiness_snapshots")
}

model Activity {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  websiteId      String?      @db.Uuid
  userId         String?      @db.Uuid
  type           ActivityType
  title          String
  description    String?
  metadataJson   Json?
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  website      Website?     @relation(fields: [websiteId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([websiteId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("activities")
}

model Task {
  id                 String        @id @default(uuid()) @db.Uuid
  websiteId          String        @db.Uuid
  organizationId     String        @db.Uuid
  auditId            String?       @db.Uuid
  title              String
  description        String?
  category           TaskCategory
  priority           TaskPriority  @default(MEDIUM)
  status             TaskStatus    @default(OPEN)
  impactScore        Int?
  effort             TaskEffort?
  source             TaskSource
  recommendationJson Json?
  resultJson         Json?
  dueAt              DateTime?
  completedAt        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  deletedAt          DateTime?

  website      Website    @relation(fields: [websiteId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  audit        Audit?     @relation(fields: [auditId], references: [id])
  planItems    PlanItem[]

  @@index([websiteId])
  @@index([organizationId])
  @@index([auditId])
  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([dueAt])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("tasks")
}

model MonthlyPlan {
  id             String            @id @default(uuid()) @db.Uuid
  websiteId      String            @db.Uuid
  organizationId String            @db.Uuid
  month          String
  status         MonthlyPlanStatus @default(DRAFT)
  goalsJson      Json?
  summary        String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  lockedAt       DateTime?

  website      Website      @relation(fields: [websiteId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  items        PlanItem[]
  articles     Article[]
  socialPosts  SocialPost[]

