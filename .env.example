# =============================================================================
# RankBoost.eu — Environment variables
# Copy to .env.local and fill in values. Never commit real secrets.
# Parsed by lib/env.ts (server: getServerEnv(), public: getPublicEnv()).
# =============================================================================

# -----------------------------------------------------------------------------
# Site (marketing — required for production SEO)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://rankboost.eu

# -----------------------------------------------------------------------------
# Database (SaaS MVP — not used by marketing site yet)
# -----------------------------------------------------------------------------
DATABASE_URL=

# Seed (optional — prisma/seed.ts)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Auth (SaaS MVP — lib/auth, prompt 4.1)
# Use long random secrets in production.
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
NEXTAUTH_SECRET=
GOOGLE_AUTH_CLIENT_ID=
GOOGLE_AUTH_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Stripe (SaaS billing — lib/billing) — TEST MODE ONLY until live launch
# Use sk_test_ / pk_test_ keys and test price IDs from Stripe Dashboard.
# Webhook routes: POST /api/billing/webhook (primary) or /api/stripe/webhook (alias)
# Local forwarding: stripe listen --forward-to localhost:3000/api/billing/webhook
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=
# App URL for checkout success/cancel redirects (e.g. http://localhost:3000 or https://www.rankboost.eu)
NEXT_PUBLIC_APP_URL=
# Optional override for Stripe Customer Portal return URL (defaults to /app/billing)
STRIPE_CUSTOMER_PORTAL_RETURN_URL=

# -----------------------------------------------------------------------------
# Resend (contact form — marketing; reports — SaaS MVP)
# -----------------------------------------------------------------------------
RESEND_API_KEY=

# Recipient for contact form submissions (internal, not shown on site)
CONTACT_EMAIL=seoagenth@gmail.com

# Sender address (use verified domain in Resend)
FROM_EMAIL=RankBoost <noreply@rankboost.eu>

# Alias for FROM_EMAIL (optional; lib/resend.ts checks both)
RESEND_FROM_EMAIL=

# Fallback if domain not verified yet:
# FROM_EMAIL=RankBoost <onboarding@resend.dev>

# -----------------------------------------------------------------------------
# Hermes (SaaS MVP — external AI worker)
# Server-side only. Never commit real secrets.
# POST /v1/generate/* endpoints are called from lib/hermes/client.ts
# Optional dev stub: HERMES_STUB_ENABLED=1 (development/test only, never production)
# -----------------------------------------------------------------------------
HERMES_API_URL=
HERMES_API_SECRET=
# Optional tuning
HERMES_MODEL=
HERMES_TIMEOUT_MS=120000
HERMES_MAX_RETRIES=0
HERMES_TEST_MODE=
# Dev-only stub (disabled in production)
HERMES_STUB_ENABLED=

# -----------------------------------------------------------------------------
# Google Integrations (SaaS MVP — GSC / GA4 / GBP OAuth)
# Prompt 8.3 / 11.12: prefer GOOGLE_CLIENT_* + GOOGLE_REDIRECT_URI + ENCRYPTION_KEY
# Legacy aliases GOOGLE_INTEGRATIONS_* and ENCRYPTION_SECRET still supported.
#
# Google Cloud Console setup (test-safe, read-only GSC):
# 1. Create/select a Google Cloud project.
# 2. Enable "Google Search Console API".
# 3. OAuth consent screen → External (or Internal) → add test users if in Testing.
# 4. Credentials → OAuth client ID → Web application.
# 5. Authorized redirect URIs (must match GOOGLE_REDIRECT_URI exactly):
#    - Local:  http://localhost:3000/api/integrations/google/callback
#    - Prod:   https://www.rankboost.eu/api/integrations/google/callback
# 6. Scope used: https://www.googleapis.com/auth/webmasters.readonly (+ openid/email/profile)
# 7. Copy client id/secret here; redeploy Vercel after adding env vars.
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

GOOGLE_INTEGRATIONS_CLIENT_ID=
GOOGLE_INTEGRATIONS_CLIENT_SECRET=
GOOGLE_INTEGRATIONS_REDIRECT_URI=

# -----------------------------------------------------------------------------
# WordPress Connector (SaaS MVP)
# -----------------------------------------------------------------------------
WORDPRESS_CONNECTOR_SECRET=

# -----------------------------------------------------------------------------
# Live publish safety (Prompt 11.51+) — default: blocked for all customers
# Do NOT clear LIVE_PUBLISH_KILL_SWITCH globally for all customers.
# First-customer rollout: set LIVE_PUBLISH_ALLOWED_WEBSITE_IDS and/or
# Website.livePublishRolloutEnabled=true (DB). Never set LIVE_PUBLISH_OPEN_TO_ALL
# on production.
# -----------------------------------------------------------------------------
# LIVE_PUBLISH_KILL_SWITCH=engaged
# LIVE_PUBLISH_ALLOWED_WEBSITE_IDS=
# LIVE_PUBLISH_MIN_QUALITY_SCORE=70
# LIVE_PUBLISH_MAX_PER_DAY=1
# LIVE_PUBLISH_FIRST_ROLLOUT_MAX_ARTICLES=1
# LIVE_PUBLISH_OPEN_TO_ALL=

# -----------------------------------------------------------------------------
# Cron (SaaS MVP — Vercel cron / scheduled jobs)
# -----------------------------------------------------------------------------
CRON_SECRET=

# -----------------------------------------------------------------------------
# Security (SaaS MVP — encryption at rest for tokens, API keys)
# 32-byte key as 64-char hex or base64. ENCRYPTION_SECRET is a legacy alias.
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=
ENCRYPTION_SECRET=
